const int BPM_BUF_SIZE = 8;
const float BPM_LOW = 40.0;
const float BPM_HIGH = 180.0;
const int HR_PASSTHROUGH_BAND = 20; //changed from 12 to 20
const int HR_SMOOTH_STEP = 15; //changed from 8 to 15
const int HR_MAX_JUMP_STABLE = 15;
const int HR_REACQ_AGREE = 15;
const int HR_COLD_LOCK_COUNT = 2;
const int HR_SEED_LOCK_COUNT = 2;
const int HR_SEED_GATE = 20;
const int HR_STUCK_LIMIT = 6;
const unsigned long HR_STALE_MS = 30000UL;
const unsigned long WARMUP_MS = 500;

int smoothedHR = 0;
float bpmBuffer[BPM_BUF_SIZE];
int bpmBufIdx = 0, bpmBufCount = 0;
long lastBeatMs = 0;
int displayHR = 0, lastKnownHR = 0;
unsigned long fingerOffTime = 0, fingerOnTime = 0;
bool reacqMode = true;
int reacqLastBeat = 0, reacqAgreeCount = 0, stuckCounter = 0;
bool fingerOn = false, warmupDone = false;
int noFingerCounter = 0;

const int32_t SPO2_BUFFER_LEN = 100;
const byte SPO2_SHIFT = 25;
uint32_t irBuffer[SPO2_BUFFER_LEN], redBuffer[SPO2_BUFFER_LEN];
int32_t spo2 = 0, maximHeartRate = 0, displaySpO2 = 0;
int8_t validSPO2 = 0, maximValidHR = 0;
byte bufferIndex = 0;
bool spo2WarmupDone = false;
int spo2ConsecutiveValid = 0;
const int SPO2_CONFIRM_COUNT = 2;

float seaLevelPressure_hPa = 1013.25;

float accumulatedGyro = 0.0, accMagSum = 0.0, accMagSqSum = 0.0;
int motionSampleCount = 0;
String motionStatus = "Unknown";
const float GYRO_STILL_THRESHOLD = 15.0, GYRO_ACTIVE_THRESHOLD = 80.0, ACC_VARIANCE_THRESHOLD = 0.01;
bool sensorError = false;

// ============================================================
// WAVEFORM BUFFER
// ============================================================
static const uint16_t PPG_SAMPLE_RATE_HZ = 50;
static const uint16_t WAVE_UPLOAD_WINDOW_SEC = 30;
static const uint16_t WAVE_UPLOAD_SAMPLES = PPG_SAMPLE_RATE_HZ * WAVE_UPLOAD_WINDOW_SEC;
static const uint16_t WAVE_RING_SECONDS = 180;
static const uint32_t WAVE_RING_SAMPLES = PPG_SAMPLE_RATE_HZ * WAVE_RING_SECONDS;
static const uint8_t WF_CHUNK_SAMPLES = 10;

uint16_t redWaveRing[WAVE_RING_SAMPLES];
uint16_t irWaveRing[WAVE_RING_SAMPLES];
uint32_t waveWriteIndex = 0, totalWaveSamplesCaptured = 0;

void storeWaveSample(uint32_t redRaw, uint32_t irRaw) {
  if (!ENABLE_WAVEFORM_TX || !fingerOn) return;
  redWaveRing[waveWriteIndex] = (uint16_t)min((uint32_t)65535, (redRaw >> 2));
  irWaveRing[waveWriteIndex]  = (uint16_t)min((uint32_t)65535, (irRaw  >> 2));
  waveWriteIndex = (waveWriteIndex + 1) % WAVE_RING_SAMPLES;
  totalWaveSamplesCaptured++;
}

void sendWaveformWindow() {
  if (!ENABLE_WAVEFORM_TX || !Bluefruit.connected() || !timeSynced) return;
  uint32_t availableSamples = min(totalWaveSamplesCaptured, (uint32_t)WAVE_RING_SAMPLES);
  if (availableSamples < WAVE_UPLOAD_SAMPLES) return;

  uint32_t seq = waveSeq++;
  int32_t startIdx = (int32_t)waveWriteIndex - (int32_t)WAVE_UPLOAD_SAMPLES;
  if (startIdx < 0) startIdx += WAVE_RING_SAMPLES;

  uint64_t endSync = syncedNowMs();
  uint64_t startSync = endSync - ((uint64_t)(WAVE_UPLOAD_SAMPLES - 1) * (1000 / PPG_SAMPLE_RATE_HZ));

  bleuart.println("WF_START,ROLE:" + String((int)DEVICE_ROLE) + ",SEQ:" + String(seq) + ",TS0:" + u64ToString(startSync) + ",DT_MS:" + String(1000 / PPG_SAMPLE_RATE_HZ) + ",N:" + String(WAVE_UPLOAD_SAMPLES));

  for (uint32_t sent = 0; sent < WAVE_UPLOAD_SAMPLES; sent += WF_CHUNK_SAMPLES) {
    String line = "WF_DATA,ROLE:" + String((int)DEVICE_ROLE) + ",SEQ:" + String(seq) + ",OFFSET:" + String(sent) + ",RED:";
    for (uint8_t i = 0; i < WF_CHUNK_SAMPLES && (sent + i) < WAVE_UPLOAD_SAMPLES; i++) {
      line += String(redWaveRing[(startIdx + sent + i) % WAVE_RING_SAMPLES]);
      if (i < WF_CHUNK_SAMPLES - 1 && (sent + i + 1) < WAVE_UPLOAD_SAMPLES) line += "|";
    }
    line += ",IR:";
    for (uint8_t i = 0; i < WF_CHUNK_SAMPLES && (sent + i) < WAVE_UPLOAD_SAMPLES; i++) {
      line += String(irWaveRing[(startIdx + sent + i) % WAVE_RING_SAMPLES]);
      if (i < WF_CHUNK_SAMPLES - 1 && (sent + i + 1) < WAVE_UPLOAD_SAMPLES) line += "|";
    }
    bleuart.println(line);
    delay(8);
  }
  bleuart.println("WF_END,ROLE:" + String((int)DEVICE_ROLE) + ",SEQ:" + String(seq));
}

// ============================================================
// HELPERS & PACKETS
// ============================================================
float getMedianBPM() {
  int n = (bpmBufCount < BPM_BUF_SIZE) ? bpmBufCount : BPM_BUF_SIZE;
  float sorted[BPM_BUF_SIZE];
  for (int i = 0; i < n; i++) sorted[i] = bpmBuffer[i];
  for (int i = 0; i < n - 1; i++) {
    for (int j = 0; j < n - i - 1; j++) {
      if (sorted[j] > sorted[j + 1]) { float tmp = sorted[j]; sorted[j] = sorted[j + 1]; sorted[j + 1] = tmp; }
    }
  }
  return sorted[n / 2];
}

void updateSmoothedHR() {
  if (displayHR == 0) { smoothedHR = 0; return; }
  if (smoothedHR == 0) { smoothedHR = displayHR; return; }
  int diff = displayHR - smoothedHR;
  if (abs(diff) <= HR_PASSTHROUGH_BAND) smoothedHR = displayHR;
  else smoothedHR += (diff > 0) ? HR_SMOOTH_STEP : -HR_SMOOTH_STEP;
}

void seedBuffer(int refHR) { for (int i = 0; i < BPM_BUF_SIZE; i++) bpmBuffer[i] = (float)refHR; bpmBufIdx = 0; bpmBufCount = BPM_BUF_SIZE; }

void enterReacq() {
  reacqMode = true; reacqLastBeat = 0; reacqAgreeCount = 0; stuckCounter = 0;
  if (displayHR > 0) { lastKnownHR = displayHR; seedBuffer(displayHR); }
  else if (lastKnownHR > 0) seedBuffer(lastKnownHR);
  displayHR = 0;
}

void resetHRState() { bpmBufIdx = 0; bpmBufCount = 0; lastBeatMs = 0; displayHR = 0; smoothedHR = 0; warmupDone = false; reacqMode = true; reacqLastBeat = 0; reacqAgreeCount = 0; stuckCounter = 0; for (int i = 0; i < BPM_BUF_SIZE; i++) bpmBuffer[i] = 0; }
void resetSpO2State() { bufferIndex = 0; spo2WarmupDone = false; spo2ConsecutiveValid = 0; }

void acceptBeat(int candidate) {
  if (reacqMode) {
    bool hasRef = (lastKnownHR > 0);
    int lockCount = hasRef ? HR_SEED_LOCK_COUNT : HR_COLD_LOCK_COUNT;
    if (hasRef && abs(candidate - lastKnownHR) > HR_SEED_GATE) { reacqLastBeat = 0; reacqAgreeCount = 0; return; }
    if (reacqLastBeat == 0) { reacqLastBeat = candidate; reacqAgreeCount = 1; return; }
    if (abs(candidate - reacqLastBeat) <= HR_REACQ_AGREE) {
      reacqAgreeCount++; reacqLastBeat = candidate;
      if (reacqAgreeCount >= lockCount) { displayHR = candidate; lastKnownHR = candidate; stuckCounter = 0; reacqMode = false; }
    } else { reacqLastBeat = candidate; reacqAgreeCount = 1; }
    return;
  }
  if (abs(candidate - displayHR) <= HR_MAX_JUMP_STABLE) { displayHR = candidate; lastKnownHR = candidate; stuckCounter = 0; }
  else { stuckCounter++; if (stuckCounter >= HR_STUCK_LIMIT) { lastKnownHR = candidate; enterReacq(); } }
}

void handleFingerDetected(long irValue) {
  noFingerCounter = 0;
  if (!fingerOn) {
    fingerOn = true; fingerOnTime = millis();
    if (lastKnownHR > 0 && fingerOffTime > 0 && (millis() - fingerOffTime) > HR_STALE_MS) lastKnownHR = 0;
    resetHRState(); resetSpO2State();
    if (lastKnownHR > 0) { seedBuffer(lastKnownHR); smoothedHR = lastKnownHR; }
    heartSensor.check(); while (heartSensor.available()) heartSensor.nextSample();
    return;
  }
  if (!warmupDone) { checkForBeat(irValue); if (millis() - fingerOnTime < WARMUP_MS) return; warmupDone = true; lastBeatMs = millis(); return; }
  if (checkForBeat(irValue)) {
    long now = millis(); long delta = now - lastBeatMs; lastBeatMs = now;
    if (delta < 333 || delta > 1500) return;
    float bpm = 60000.0f / (float)delta;
    if (bpm < BPM_LOW || bpm > BPM_HIGH) return;
    bpmBuffer[bpmBufIdx % BPM_BUF_SIZE] = bpm; bpmBufIdx++;
    if (bpmBufCount < BPM_BUF_SIZE) bpmBufCount++;
    acceptBeat((int)(getMedianBPM() + 0.5f));
  }
}

void handleFingerRemoved() {
  noFingerCounter++;
  if (noFingerCounter > 300) { //changed multiple times
    if (displayHR > 0) { lastKnownHR = displayHR; fingerOffTime = millis(); }
    fingerOn = false; /*displayHR = 0; displaySpO2 = 0;*/ resetHRState();
  }
}

void shiftSpO2Buffer() { for (byte i = SPO2_SHIFT; i < SPO2_BUFFER_LEN; i++) { redBuffer[i - SPO2_SHIFT] = redBuffer[i]; irBuffer[i - SPO2_SHIFT] = irBuffer[i]; } bufferIndex = SPO2_BUFFER_LEN - SPO2_SHIFT; }

void processSpO2Buffer() {
  if (!fingerOn) { bufferIndex = 0; return; }
  if (!spo2WarmupDone) { spo2WarmupDone = true; bufferIndex = 0; return; }
  maxim_heart_rate_and_oxygen_saturation(irBuffer, SPO2_BUFFER_LEN, redBuffer, &spo2, &validSPO2, &maximHeartRate, &maximValidHR);
  if (validSPO2 == 1 && spo2 >= 85 && spo2 <= 100) {
    spo2ConsecutiveValid++; if (spo2ConsecutiveValid >= SPO2_CONFIRM_COUNT) displaySpO2 = spo2;
  } else spo2ConsecutiveValid = 0;
  shiftSpO2Buffer();
}

void sampleIMU() {
  float gx = myIMU.readFloatGyroX(), gy = myIMU.readFloatGyroY(), gz = myIMU.readFloatGyroZ();
  accumulatedGyro += sqrt(gx*gx + gy*gy + gz*gz);
  float ax = myIMU.readFloatAccelX(), ay = myIMU.readFloatAccelY(), az = myIMU.readFloatAccelZ();
  float am = sqrt(ax*ax + ay*ay + az*az);
  accMagSum += am; accMagSqSum += am * am; motionSampleCount++;
}

void evaluateMotionStatus() {
  if (motionSampleCount == 0) return;
  float n = (float)motionSampleCount, meanMag = accMagSum / n, accVar = (accMagSqSum / n) - (meanMag * meanMag);
  float avgGyro = accumulatedGyro / n;
  accumulatedGyro = 0; accMagSum = 0; accMagSqSum = 0; motionSampleCount = 0;
  if (avgGyro < GYRO_STILL_THRESHOLD && accVar < ACC_VARIANCE_THRESHOLD) motionStatus = "Still";
  else if (avgGyro > GYRO_ACTIVE_THRESHOLD) motionStatus = "Active Motion";
  else motionStatus = "Minor Motion";
}


void sendVitalsPacket() {
  updateSmoothedHR();
  evaluateMotionStatus();

  String packet = "VT";
  packet += ",ROLE:"    + String((int)DEVICE_ROLE);
  packet += ",SEQ:"     + String(vitalsSeq++);
  packet += ",LOCAL_MS:" + String(millis());
  packet += ",SYNC_MS:" + u64ToString(syncedNowMs());
  packet += ",SYNCED:"  + String(timeSynced ? 1 : 0);
  packet += ",CONTACT:" + String(fingerOn ? 1 : 0);
  packet += ",HR:"      + String(smoothedHR);
  packet += ",SPO2:"    + String(displaySpO2);

  // Only read BMP280 if it initialized successfully
  if (!sensorError) {
    float tempC = bmp.readTemperature() + TEMP_CALIBRATION_OFFSET_C;
    float pressure = bmp.readPressure() / 100.0f;
    //using standard sea level pressure as reference, not the measured pressure
    float altitude = bmp.readAltitude(1013.25f);

    // Replace NaN with 0 before sending
    if (isnan(tempC))    tempC    = 0.0f;
    if (isnan(pressure)) pressure = 0.0f;
    if (isnan(altitude)) altitude = 0.0f;
    
    
    float tempF = tempC * 1.8f + 32.0f;
    
    packet += ",TEMP_F:" + String(tempF, 1);
    packet += ",PRESS:"  + String(pressure, 1);
    packet += ",ALT:"    + String(altitude, 1);
  } else {
    // Send zeros so the parser sees valid numbers instead of "nan"
    packet += ",TEMP_F:0.0,PRESS:0.0,ALT:0.0";
  }

  // Motion must be last — it can contain spaces which affect parsing
  packet += ",MOTION:" + motionStatus;

  Serial.println(packet);
  if (Bluefruit.connected()) {
    bleuart.println(packet);
  }
}
void scanI2C() {
  Serial.println("Scanning I2C bus...");
  int found = 0;
  for (byte addr = 1; addr < 127; addr++) {
    Wire.beginTransmission(addr);
    byte error = Wire.endTransmission();
    if (error == 0) {
      Serial.print("Device found at 0x");
      if (addr < 16) Serial.print("0");
      Serial.println(addr, HEX);
      found++;
    }
  }
  if (found == 0) Serial.println("No I2C devices found");
  else Serial.println("I2C scan complete");
}
void setup() {
  Serial.begin(115200); delay(5000);
  Serial.println("=== HALO BOOT ===");
  pinMode(LED_RED, OUTPUT); pinMode(LED_GREEN, OUTPUT); pinMode(LED_BLUE, OUTPUT);
  digitalWrite(LED_RED, HIGH); digitalWrite(LED_GREEN, HIGH); digitalWrite(LED_BLUE, HIGH);
  Wire.begin();
  scanI2C();  // add this line
  //if (!bmp.begin(0x76)&& !bmp.begin(0x77)) { Serial.println("BMP280 fail"); sensorError = true; }
  // With this — tries both I2C addresses:
  if (!bmp.begin(0x76) && !bmp.begin(0x77)) {
      Serial.println("BMP280 fail — tried 0x76 and 0x77");
      sensorError = true;
  } else {
      Serial.println("BMP280 OK");
}
  if (!heartSensor.begin(Wire, I2C_SPEED_FAST)) { Serial.println("MAX30105 fail"); sensorError = true; }
  else { heartSensor.setup(); heartSensor.setPulseAmplitudeRed(0x1F); heartSensor.setPulseAmplitudeIR(0x1F); }
  if (myIMU.begin() != 0) { Serial.println("LSM6DS3 fail"); sensorError = true; }
  Bluefruit.configPrphBandwidth(BANDWIDTH_MAX); Bluefruit.begin(); Bluefruit.setName(roleName(DEVICE_ROLE)); bleuart.begin();
  Bluefruit.Advertising.addFlags(BLE_GAP_ADV_FLAGS_LE_ONLY_GENERAL_DISC_MODE);
  Bluefruit.Advertising.addService(bleuart); Bluefruit.ScanResponse.addName();
  Bluefruit.Advertising.restartOnDisconnect(true); Bluefruit.Advertising.start(0);
}

void loop() {
  pollBleRx(); heartSensor.check();
  while (heartSensor.available()) {
    uint32_t r = heartSensor.getFIFORed(), i = heartSensor.getFIFOIR();
    redBuffer[bufferIndex] = r; irBuffer[bufferIndex] = i;
    if (i > 50000) { handleFingerDetected(i); storeWaveSample(r, i); }
    else handleFingerRemoved();
    heartSensor.nextSample(); bufferIndex++;
    if (bufferIndex >= SPO2_BUFFER_LEN) processSpO2Buffer();
  }
  unsigned long now = millis();
  if (now - lastImuReadTime >= IMU_READ_INTERVAL_MS) { lastImuReadTime = now; sampleIMU(); }
  if (Bluefruit.connected() && (now - lastTimeSyncRequestMs >= TIME_SYNC_REQUEST_MS || !timeSynced)) { lastTimeSyncRequestMs = now; requestTimeSync(); }
  if (now - lastVitalsTxTime >= VITALS_TX_INTERVAL_MS) { lastVitalsTxTime = now; sendVitalsPacket(); }
  if (ENABLE_WAVEFORM_TX && Bluefruit.connected() && timeSynced && (now - lastWaveUploadTime >= WAVE_UPLOAD_PERIOD_MS)) { lastWaveUploadTime = now; sendWaveformWindow(); }
}

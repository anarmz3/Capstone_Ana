// ============================================================
// TIME SYNC
// ============================================================
int64_t clockOffsetMs = 0;
bool timeSynced = false;
uint32_t vitalsSeq = 0;
uint32_t waveSeq = 0;
uint32_t tsAckSeq = 0;

uint64_t syncedNowMs() {
  return (uint64_t)((int64_t)millis() + clockOffsetMs);
}

// FIXED: Manual u64 conversion to avoid "lu" formatting bug
String u64ToString(uint64_t value) {
  if (value == 0) return "0";
  String s = "";
  while (value > 0) {
    s = String((uint8_t)(value % 10)) + s;
    value /= 10;
  }
  return s;
}

void applyTimeSyncFromApp(uint64_t appEpochMs) {
  clockOffsetMs = (int64_t)appEpochMs - (int64_t)millis();
  timeSynced = true;
}

void sendTimeSyncAck(uint64_t appEpochMs) {
  if (!Bluefruit.connected()) return;
  String ack = "TS_ACK,ROLE:" + String((int)DEVICE_ROLE) + ",SEQ:" + String(tsAckSeq++) + ",LOCAL_MS:" + String(millis()) + ",SYNC_MS:" + u64ToString(syncedNowMs()) + ",APP_MS:" + u64ToString(appEpochMs);
  bleuart.println(ack);
}

void requestTimeSync() {
  if (!Bluefruit.connected()) return;
  String req = "TS_REQ,ROLE:" + String((int)DEVICE_ROLE) + ",LOCAL_MS:" + String(millis()) + ",SYNC_MS:" + u64ToString(syncedNowMs()) + ",SYNCED:" + String(timeSynced ? 1 : 0);
  bleuart.println(req);
}

// ============================================================
// BLE RX
// ============================================================
String bleRxLine = "";

void handleBleIncomingLine(const String& line) {
  if (!line.startsWith("TS,")) return;
  int idx = line.indexOf("APP_MS:");
  if (idx < 0) return;
  int start = idx + 7;
  int end = line.indexOf(',', start);
  String epochStr = (end < 0) ? line.substring(start) : line.substring(start, end);
  uint64_t appEpochMs = strtoull(epochStr.c_str(), nullptr, 10);
  applyTimeSyncFromApp(appEpochMs);
  sendTimeSyncAck(appEpochMs);
}

void pollBleRx() {
  while (bleuart.available()) {
    char c = (char)bleuart.read();
    if (c == '\n' || c == '\r') {
      if (bleRxLine.length() > 0) {
        handleBleIncomingLine(bleRxLine);
        bleRxLine = "";
      }
    } else {
      bleRxLine += c;
      if (bleRxLine.length() > 180) bleRxLine = "";
    }
  }
}

